LOG_ANALYZER_PORT=5071

YANDEX_CLIENT_ID=replace-with-yandex-client-id
YANDEX_CLIENT_SECRET=replace-with-yandex-client-secret
AUTHENTICATION_ENABLED=true
PUBLIC_ORIGIN=https://log-analyzer.example.com

METADATA_PROVIDER=PostgreSQL
POSTGRES_DB=log_analyzer
POSTGRES_USER=log_analyzer
POSTGRES_PASSWORD=replace-with-strong-postgres-password

CLICKHOUSE_DB=log_analyzer
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
