@inject IOptions<AppAuthenticationOptions> AuthOptions
@inject NavigationManager Navigation

<Router AppAssembly="typeof(Program).Assembly">
    <Found Context="routeData">
        @if (ShouldRequireAuthentication(routeData))
        {
            <AuthorizeView>
                <Authorized>
                    <RouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)" />
                </Authorized>
                <NotAuthorized>
                    <LayoutView Layout="typeof(Layout.PublicLayout)">
                        <LoginLanding ReturnUrl="@CurrentReturnUrl" />
                    </LayoutView>
                </NotAuthorized>
                <Authorizing>
                    <LayoutView Layout="typeof(Layout.PublicLayout)">
                        <section class="empty-state">
                            <h1>Проверяем сессию</h1>
                        </section>
                    </LayoutView>
                </Authorizing>
            </AuthorizeView>
        }
        else
        {
            <RouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)" />
        }
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
    <NotFound>
        <LayoutView Layout="typeof(Layout.MainLayout)">
            <section class="empty-state">
                <h1>Страница не найдена</h1>
                <p>Проверьте адрес или вернитесь к списку проектов.</p>
                <a class="btn btn-primary" href="">К проектам</a>
            </section>
        </LayoutView>
    </NotFound>
</Router>

@code {
    private bool ShouldRequireAuthentication(RouteData routeData)
    {
        return AuthOptions.Value.Enabled && !AllowsAnonymous(routeData);
    }

    private static bool AllowsAnonymous(RouteData routeData)
    {
        return routeData.PageType
            .GetCustomAttributes(typeof(AllowAnonymousAttribute), inherit: true)
            .Any();
    }

    private string CurrentReturnUrl
    {
        get
        {
            var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri);
            return string.IsNullOrWhiteSpace(relativePath) ? "/" : $"/{relativePath}";
        }
    }
}
