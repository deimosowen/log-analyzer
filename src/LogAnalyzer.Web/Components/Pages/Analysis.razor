@page "/projects/{ProjectId}/analysis"
@rendermode InteractiveServer
@inject IMetadataRepository Metadata
@inject ILogEventStore EventStore
@inject ICurrentUserService CurrentUserService
@inject NavigationManager Navigation

<PageTitle>Анализ инцидента</PageTitle>

@if (project is null)
{
    <section class="empty-state">
        <h1>Проект не найден</h1>
        <button class="btn btn-primary" @onclick="BackToProjects">К проектам</button>
    </section>
}
else
{
    <div class="analysis-shell">
        <header class="analysis-topbar">
            <div class="analysis-title-row">
                <button class="icon-button" title="К проекту" @onclick="BackToProject">←</button>
                <div>
                    <span class="eyebrow">Анализ инцидента</span>
                    <h1>@project.Name</h1>
                </div>
            </div>

            <div class="analysis-controls" aria-label="Фильтры анализа">
                <label class="compact-field search-field">
                    <span>Поиск</span>
                    <input class="form-control" @bind="query" @bind:event="oninput" placeholder="сообщение, URL, exception" />
                </label>

                <div class="window-control" aria-label="Окно корреляции">
                    <span>Окно</span>
                    <label title="Секунд до выбранного события">
                        <span>-</span>
                        <input type="number" class="form-control number-input" @bind="beforeSeconds" min="0" @bind:after="RefreshCorrelation" />
                        <em>с</em>
                    </label>
                    <label title="Секунд после выбранного события">
                        <span>+</span>
                        <input type="number" class="form-control number-input" @bind="afterSeconds" min="0" @bind:after="RefreshCorrelation" />
                        <em>с</em>
                    </label>
                </div>

                <label class="compact-field timezone-field">
                    <span>Часовой пояс</span>
                    <input class="form-control" @bind="displayTimeZoneId" />
                </label>

                <div class="toolbar-actions">
                    <button class="btn btn-primary" @onclick="Refresh">Применить</button>
                    <button class="btn btn-outline-secondary" @onclick="ResetView">Сброс</button>
                </div>
            </div>
        </header>

        <details class="source-drawer">
            <summary>
                <div class="source-heading">
                    <strong>Логи</strong>
                    <span>выбрано @selectedLogIds.Count из @logs.Count</span>
                </div>
                <span class="selected-log-preview">@SelectedLogPreview</span>
            </summary>
            <div class="source-chips">
                @foreach (var log in logs)
                {
                    var stat = stats.GetValueOrDefault(log.Id);
                    <label class="source-chip @(selectedLogIds.Contains(log.Id) ? "active" : "")">
                        <input type="checkbox" checked="@selectedLogIds.Contains(log.Id)" @onchange="value => ToggleLog(log.Id, value)" />
                        <span>
                            <strong title="@log.DisplayName">@LogDisplayName(log)</strong>
                            <small>@(stat?.ErrorCount ?? 0) ошибок · @(stat?.WarnCount ?? 0) предупреждений</small>
                        </span>
                    </label>
                }
            </div>
        </details>

        <section class="incident-map-panel @(selectedEvent is null ? "is-empty" : "") @(showIncidentTimeline ? "" : "is-collapsed")">
            <div class="panel-heading incident-map-heading">
                <div>
                    <span class="eyebrow">Карта инцидента</span>
                    <h2>Timeline выбранной проблемы</h2>
                </div>
                <div class="panel-actions incident-map-actions">
                    @if (selectedEvent is not null)
                    {
                        <div class="incident-map-stats">
                            <span>@incidentTimeline.TotalCount событий</span>
                            <span>пик @incidentTimeline.MaxBucketCount</span>
                            <span>bucket @FormatBucket(incidentTimeline.Bucket)</span>
                        </div>
                    }
                    <button class="ghost-button" @onclick="ToggleIncidentTimeline">
                        @(showIncidentTimeline ? "Скрыть" : "Показать")
                    </button>
                </div>
            </div>

            @if (!showIncidentTimeline)
            {
                <div class="incident-map-collapsed">
                    @if (selectedEvent is null)
                    {
                        <span>Карта свернута. Выберите проблему, чтобы построить timeline.</span>
                    }
                    else if (incidentTimeline.IsEmpty)
                    {
                        <span>Карта свернута. В выбранном окне событий нет.</span>
                    }
                    else
                    {
                        <span>@FormatTime(incidentTimeline.FromUtc) - @FormatTime(incidentTimeline.ToUtc)</span>
                    }
                </div>
            }
            else if (selectedEvent is null)
            {
                <div class="incident-map-empty">
                    <strong>Выберите проблему</strong>
                    <span>Timeline покажет всплески ошибок вокруг выбранного события.</span>
                </div>
            }
            else if (incidentTimeline.IsEmpty)
            {
                <div class="incident-map-empty">
                    <strong>В этом окне нет событий</strong>
                    <span>Измените окно корреляции или набор логов.</span>
                </div>
            }
            else
            {
                <div class="incident-chart-frame">
                    <div id="@timelineChartElementId" class="incident-chart" role="img" aria-label="Timeline инцидента"></div>
                </div>
                <div class="timeline-footer">
                    <span>@FormatTime(incidentTimeline.FromUtc)</span>
                    <span>Выделите колесом/ползунком нужный фрагмент, кликните по всплеску для фокуса</span>
                    <span>@FormatTime(incidentTimeline.ToUtc)</span>
                </div>
            }
        </section>

        <main class="@StageClass">
            @if (showStep1)
            {
            <section class="problem-panel">
                <div class="panel-heading problem-heading">
                    <div>
                        <span class="eyebrow">Шаг 1</span>
                        <h2>Выберите проблему</h2>
                    </div>
                    <div class="panel-actions">
                        <div class="level-row">
                            @foreach (var level in ProblemLevels)
                            {
                                <label class="level-chip @(selectedLevels.Contains(level) ? "active" : "")">
                                    <input type="checkbox" checked="@selectedLevels.Contains(level)" @onchange="value => ToggleLevel(level, value)" />
                                    @level
                                </label>
                            }
                        </div>
                        <button class="ghost-button" @onclick="ToggleStep1">Скрыть</button>
                    </div>
                </div>

                <div class="problem-table">
                    <div class="problem-header">
                        <span>время</span>
                        <span>уровень</span>
                        <span>лог</span>
                        <span>сообщение</span>
                    </div>
                    <Virtualize @ref="problemVirtualize" Context="item" ItemsProvider="LoadProblems" ItemSize="48">
                        <ItemContent>
                            <button class="problem-row @(selectedEvent?.Id == item.Id ? "selected" : "")" @onclick="() => SelectProblem(item)">
                                <span>@FormatTime(item.TimestampUtc)</span>
                                <span class="level-pill @item.Level">@DisplayLevel(item.Level)</span>
                                <span>@LogName(item.LogFileId)</span>
                                <strong>@item.Message</strong>
                            </button>
                        </ItemContent>
                        <Placeholder>
                            <div class="problem-row loading-row">
                                <span>Загрузка</span>
                            </div>
                        </Placeholder>
                    </Virtualize>
                </div>
            </section>
            }
            else
            {
            <section class="collapsed-step">
                <div>
                    <span class="eyebrow">Шаг 1</span>
                    <strong>@(selectedEvent is null ? "Проблема не выбрана" : selectedEvent.Message)</strong>
                </div>
                <button class="ghost-button" @onclick="ToggleStep1">Показать</button>
            </section>
            }

            @if (showStep2)
            {
            <section class="correlation-panel @(selectedEvent is null ? "is-empty" : "")">
                <div class="panel-heading correlation-heading">
                    <div>
                        <span class="eyebrow">Шаг 2</span>
                        <h2>Проблемы в выбранном окне времени</h2>
                    </div>
                    <div class="panel-actions">
                        @if (selectedEvent is not null)
                        {
                            <span>@CorrelationCountLabel · @beforeSeconds сек до / @afterSeconds сек после</span>
                            <div class="segmented-control" aria-label="Режим отображения">
                                <button class="@(correlationMode == CorrelationDisplayMode.Summary ? "active" : "")" @onclick="ShowCorrelationSummary">Сводка</button>
                                <button class="@(correlationMode == CorrelationDisplayMode.Events ? "active" : "")" @onclick="ShowCorrelationEvents">Строки</button>
                                <button class="@(correlationMode == CorrelationDisplayMode.Http ? "active" : "")" @onclick="ShowHttpAnalysis">HTTP</button>
                            </div>
                            <label class="inline-toggle" title="Скрывать успешные IIS-запросы из общей корреляции">
                                <input type="checkbox" @bind="hideSuccessfulHttp" @bind:after="RefreshCorrelation" />
                                без 2xx/3xx
                            </label>
                            <button class="ghost-button" @onclick="ExportMarkdownReport">Отчет MD</button>
                        }
                        <button class="ghost-button" @onclick="ToggleStep2">Скрыть</button>
                    </div>
                </div>

                @if (selectedEvent is null)
                {
                    <div class="selection-empty">
                        <strong>Выберите проблему выше</strong>
                        <span>Здесь появятся проблемы из остальных логов за выбранное окно времени.</span>
                    </div>
                }
                else
                {
                    <div class="selected-problem-card">
                        <span class="level-pill @selectedEvent.Level">@DisplayLevel(selectedEvent.Level)</span>
                        <div>
                            <strong>@selectedEvent.Message</strong>
                            <small>@FormatTime(selectedEvent.TimestampUtc) · @LogName(selectedEvent.LogFileId) · строка @selectedEvent.LineNumber</small>
                        </div>
                    </div>

                    @if (correlationMode == CorrelationDisplayMode.Http)
                    {
                        <div class="http-analysis">
                            <div class="http-filter-bar">
                                <label>
                                    <span>Статус</span>
                                    <select class="form-control" @bind="httpStatusClassFilter">
                                        <option value="">Все</option>
                                        <option value="5">5xx</option>
                                        <option value="4">4xx</option>
                                        <option value="3">3xx</option>
                                        <option value="2">2xx</option>
                                    </select>
                                </label>
                                <label>
                                    <span>Метод</span>
                                    <input class="form-control" @bind="httpMethodFilter" placeholder="GET" />
                                </label>
                                <label>
                                    <span>URL</span>
                                    <input class="form-control" @bind="httpUrlFilter" placeholder="/api/orders" />
                                </label>
                                <label>
                                    <span>IP</span>
                                    <input class="form-control" @bind="httpClientIpFilter" placeholder="10.0.0.1" />
                                </label>
                                <label>
                                    <span>Пользователь</span>
                                    <input class="form-control" @bind="httpUserNameFilter" placeholder="domain\\user" />
                                </label>
                                <label>
                                    <span>Медленнее, мс</span>
                                    <input type="number" class="form-control" @bind="httpMinTimeTaken" min="0" />
                                </label>
                                <div class="http-filter-actions">
                                    <button class="btn btn-primary" @onclick="ApplyHttpFilters">Применить</button>
                                    <button class="ghost-button" @onclick="ResetHttpFilters">Сброс</button>
                                </div>
                            </div>

                            @if (iisAnalysis.Summary.TotalRequests == 0)
                            {
                                <div class="correlation-empty">В этом окне IIS-запросов не найдено.</div>
                            }
                            else
                            {
                                <div class="http-metrics">
                                    <article>
                                        <span>Запросов</span>
                                        <strong>@FormatCount(iisAnalysis.Summary.TotalRequests)</strong>
                                    </article>
                                    <article>
                                        <span>5xx</span>
                                        <strong>@FormatCount(iisAnalysis.Summary.ServerErrorCount)</strong>
                                    </article>
                                    <article>
                                        <span>4xx</span>
                                        <strong>@FormatCount(iisAnalysis.Summary.ClientErrorCount)</strong>
                                    </article>
                                    <article>
                                        <span>Медленных</span>
                                        <strong>@FormatCount(iisAnalysis.Summary.SlowRequestCount)</strong>
                                    </article>
                                    <article>
                                        <span>p95</span>
                                        <strong>@FormatMilliseconds(iisAnalysis.Summary.P95TimeTaken)</strong>
                                    </article>
                                    <article>
                                        <span>max</span>
                                        <strong>@FormatMilliseconds(iisAnalysis.Summary.MaxTimeTaken)</strong>
                                    </article>
                                </div>

                                <div class="http-insight-grid">
                                    <section class="http-insight-card">
                                        <header>
                                            <span class="eyebrow">5xx</span>
                                            <strong>Серверные ошибки</strong>
                                        </header>
                                        @foreach (var item in iisAnalysis.ServerErrorEndpoints)
                                        {
                                            <button class="http-aggregate-row" @onclick="() => OpenHttpAggregate(item)">
                                                <span class="status-pill server">@FormatHttpStatusClass(item.StatusCodeClass)</span>
                                                <strong>@item.Method @item.Url</strong>
                                                <small>@FormatCount(item.Count) · p95 @FormatMilliseconds(item.P95TimeTaken) · max @FormatMilliseconds(item.MaxTimeTaken)</small>
                                            </button>
                                        }
                                    </section>

                                    <section class="http-insight-card">
                                        <header>
                                            <span class="eyebrow">4xx</span>
                                            <strong>Клиентские ошибки</strong>
                                        </header>
                                        @foreach (var item in iisAnalysis.ClientErrorEndpoints)
                                        {
                                            <button class="http-aggregate-row" @onclick="() => OpenHttpAggregate(item)">
                                                <span class="status-pill client">@FormatHttpStatusClass(item.StatusCodeClass)</span>
                                                <strong>@item.Method @item.Url</strong>
                                                <small>@FormatCount(item.Count) · p95 @FormatMilliseconds(item.P95TimeTaken) · max @FormatMilliseconds(item.MaxTimeTaken)</small>
                                            </button>
                                        }
                                    </section>

                                    <section class="http-insight-card">
                                        <header>
                                            <span class="eyebrow">Latency</span>
                                            <strong>Медленные endpoint'ы</strong>
                                        </header>
                                        @foreach (var item in iisAnalysis.SlowEndpoints)
                                        {
                                            <button class="http-aggregate-row" @onclick="() => OpenHttpAggregate(item)">
                                                <span class="status-pill slow">@FormatMilliseconds(item.P95TimeTaken)</span>
                                                <strong>@item.Method @item.Url</strong>
                                                <small>@FormatCount(item.Count) · @FormatHttpStatusClass(item.StatusCodeClass) · max @FormatMilliseconds(item.MaxTimeTaken)</small>
                                            </button>
                                        }
                                    </section>
                                </div>

                                <div class="http-detail-grid">
                                    <section class="http-insight-card">
                                        <header>
                                            <span class="eyebrow">Requests</span>
                                            <strong>Самые медленные запросы</strong>
                                        </header>
                                        @foreach (var item in iisAnalysis.SlowRequests)
                                        {
                                            <div class="http-request-row">
                                                <span>@FormatTime(item.TimestampUtc)</span>
                                                <strong>@item.Method @item.Url</strong>
                                                <small>@item.StatusCode · @FormatMilliseconds(item.TimeTaken) · @item.ClientIp · @LogName(item.LogFileId)</small>
                                            </div>
                                        }
                                    </section>

                                    <section class="http-insight-card">
                                        <header>
                                            <span class="eyebrow">Drill-down</span>
                                            <strong>Запросы выбранной группы</strong>
                                        </header>
                                        @if (httpDrilldownEvents.Count == 0)
                                        {
                                            <div class="http-card-empty">Выберите строку в агрегатах.</div>
                                        }
                                        else
                                        {
                                            @foreach (var item in httpDrilldownEvents)
                                            {
                                                <button class="http-request-row interactive" @onclick="() => SelectProblem(item)">
                                                    <span>@FormatTime(item.TimestampUtc)</span>
                                                    <strong>@item.HttpMethod @item.Url</strong>
                                                    <small>@item.StatusCode · @FormatMilliseconds(item.TimeTaken) · @item.ClientIp · @LogName(item.LogFileId)</small>
                                                </button>
                                            }
                                        }
                                    </section>
                                </div>
                            }
                        </div>
                    }
                    else if (correlatedEvents.Count == 0)
                    {
                        <div class="correlation-empty">В этом окне времени проблем не найдено.</div>
                    }
                    else if (correlationMode == CorrelationDisplayMode.Summary)
                    {
                        @if (IsCorrelationTruncated)
                        {
                            <div class="result-note">
                                Показаны первые @correlatedEvents.Count из @correlatedTotalCount событий. Для полной картины сузьте окно или выберите меньше логов.
                            </div>
                        }
                        <div class="correlation-table summary-table">
                            <div class="correlation-header summary-header">
                                <span>кол-во</span>
                                <span>окно</span>
                                <span>уровень</span>
                                <span>логов</span>
                                <span>группа</span>
                            </div>
                            @foreach (var group in correlationGroups)
                            {
                                <button class="correlation-line summary-line @(selectedEvent.Id == group.Representative.Id ? "active" : "")" @onclick="() => SelectProblem(group.Representative)">
                                    <span class="count-pill">@group.Count</span>
                                    <span>@FormatGroupWindow(group)</span>
                                    <span class="level-pill @group.Level">@DisplayLevel(group.Level)</span>
                                    <span>@group.LogCount</span>
                                    <strong>@group.Title</strong>
                                </button>
                            }
                        </div>
                    }
                    else
                    {
                        @if (IsCorrelationTruncated)
                        {
                            <div class="result-note">
                                Показаны первые @correlatedEvents.Count из @correlatedTotalCount событий. Для полной картины сузьте окно или выберите меньше логов.
                            </div>
                        }
                        <div class="correlation-table">
                            <div class="correlation-header">
                                <span>дельта</span>
                                <span>время</span>
                                <span>уровень</span>
                                <span>лог</span>
                                <span>сообщение</span>
                            </div>
                            @foreach (var item in correlatedEvents)
                            {
                                <button class="correlation-line @(selectedEvent.Id == item.Id ? "active" : "")" @onclick="() => SelectProblem(item)">
                                    <span>@FormatDelta(item)</span>
                                    <span>@FormatTime(item.TimestampUtc)</span>
                                    <span class="level-pill @item.Level">@DisplayLevel(item.Level)</span>
                                    <span>@LogName(item.LogFileId)</span>
                                    <strong>@item.Message</strong>
                                </button>
                            }
                        </div>
                    }

                    <details class="event-details">
                        <summary>Детали выбранного события</summary>
                        <dl class="details-grid">
                            <dt>Источник</dt><dd>@selectedEvent.Source</dd>
                            <dt>Поток</dt><dd>@selectedEvent.ThreadId</dd>
                            <dt>Время</dt><dd>@FormatTime(selectedEvent.TimestampUtc)</dd>
                            @if (!string.IsNullOrWhiteSpace(selectedEvent.HttpMethod) || selectedEvent.StatusCode > 0)
                            {
                                <dt>HTTP</dt><dd>@selectedEvent.HttpMethod @selectedEvent.Url @selectedEvent.StatusCode · @selectedEvent.TimeTaken мс</dd>
                                <dt>Клиент</dt><dd>@selectedEvent.ClientIp</dd>
                                <dt>Сервер</dt><dd>@selectedEvent.ServerIp</dd>
                            }
                        </dl>
                        <pre>@selectedEvent.RawText</pre>
                        @if (!string.IsNullOrWhiteSpace(selectedEvent.Exception))
                        {
                            <pre>@selectedEvent.Exception</pre>
                        }
                    </details>
                }
            </section>
            }
            else
            {
            <section class="collapsed-step">
                <div>
                    <span class="eyebrow">Шаг 2</span>
                    <strong>@(selectedEvent is null ? "Окно корреляции скрыто" : CorrelationCountLabel)</strong>
                </div>
                <button class="ghost-button" @onclick="ToggleStep2">Показать</button>
            </section>
            }
        </main>
    </div>
}
