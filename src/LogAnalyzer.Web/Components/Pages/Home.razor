@page "/"
@rendermode InteractiveServer

<PageTitle>Проекты</PageTitle>

<div class="dashboard-shell">
    <header class="dashboard-header">
        <div>
            <span class="eyebrow">Рабочая область</span>
            <h1>Проекты с логами</h1>
            <p>Загружайте логи, выбирайте проблемное событие и смотрите, что происходило рядом по времени.</p>
        </div>
        <div class="user-badge">
            <span>@currentUser.DisplayName</span>
            <small>@currentUser.Email</small>
        </div>
    </header>

    <section class="metric-grid">
        <div class="metric-tile">
            <span>Проекты</span>
            <strong>@projects.Count</strong>
        </div>
        <div class="metric-tile">
            <span>Логи</span>
            <strong>@logCount</strong>
        </div>
        <div class="metric-tile">
            <span>События</span>
            <strong>@eventCount</strong>
        </div>
        <div class="metric-tile accent">
            <span>Проблемы</span>
            <strong>@problemCount</strong>
        </div>
    </section>

    <section class="create-project-panel">
        <div>
            <span class="eyebrow">Новый разбор</span>
            <h2>Создать проект</h2>
        </div>
        <div class="create-project-form">
            <label>
                Название
                <input class="form-control" @bind="newName" placeholder="Инцидент API 2026-04-21" />
            </label>
            <label>
                Контекст
                <input class="form-control" @bind="newDescription" placeholder="Сервис, релиз, короткое описание" />
            </label>
            <button class="btn btn-primary" @onclick="CreateProject" disabled="@isBusy">Создать</button>
        </div>
        @if (!string.IsNullOrWhiteSpace(error))
        {
            <div class="alert alert-danger mt-3">@error</div>
        }
    </section>

    <section class="project-board">
        <div class="section-title">
            <div>
                <span class="eyebrow">Ваши проекты</span>
                <h2>Последние разборы</h2>
            </div>
        </div>

        @if (projects.Count == 0)
        {
            <div class="empty-state">
                <h2>Пока нет проектов</h2>
                <p>Создайте первый проект, загрузите логи и откройте анализ инцидента.</p>
            </div>
        }
        else
        {
            <div class="project-grid">
                @foreach (var project in projects)
                {
                    var summary = summaries.GetValueOrDefault(project.Id);
                    <article class="project-card">
                        <div>
                            <h3>@project.Name</h3>
                            <p>@project.Description</p>
                        </div>
                        <div class="project-card-stats">
                            <span>@(summary?.LogCount ?? 0) логов</span>
                            <span>@(summary?.EventCount ?? 0) событий</span>
                            <span>@(summary?.ProblemCount ?? 0) проблем</span>
                        </div>
                        <div class="project-card-footer">
                            <small>@project.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</small>
                            <div class="row-actions">
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => OpenProject(project.Id)">Открыть</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteProject(project.Id)">Удалить</button>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
    </section>
</div>
