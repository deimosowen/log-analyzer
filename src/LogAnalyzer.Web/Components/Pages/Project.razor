@page "/projects/{ProjectId}"
@rendermode InteractiveServer

<PageTitle>Загрузка логов</PageTitle>

@if (project is null)
{
    <section class="empty-state">
        <h1>Проект не найден</h1>
        <button class="btn btn-primary" @onclick="BackToProjects">К проектам</button>
    </section>
}
else
{
    <div class="project-shell">
    <header class="project-header">
        <div>
            <span class="eyebrow">Загрузка логов</span>
            <h1>@project.Name</h1>
            <p>@project.Description</p>
        </div>
        <div class="header-actions">
            <button class="btn btn-outline-secondary" @onclick="LoadData">Обновить</button>
            @if (IsProjectOwner)
            {
                <button class="btn btn-outline-primary" @onclick="OpenShareModalAsync" disabled="@shareBusy">Поделиться</button>
            }
            <button class="btn btn-primary" @onclick="OpenAnalysis">Анализ инцидента</button>
        </div>
    </header>

    <section class="upload-panel">
        <div class="upload-panel-main">
            <div>
                <span class="eyebrow">Шаг 1</span>
                <h2>Выберите файлы</h2>
                <p>Можно загрузить отдельные `.log`, `.txt`, `.csv` или архивы `.zip` / `.7z` / `.rar`; вложенные папки в архиве поддерживаются.</p>
            </div>
            <InputFile class="form-control file-input" OnChange="OnFilesSelected" multiple />
            @if (selectedFiles.Any())
            {
                <div class="file-list">
                    @foreach (var file in selectedFiles)
                    {
                        <span>@file.Name (@FormatBytes(file.Size))</span>
                    }
                </div>
            }
        </div>

        <aside class="upload-settings">
            <div>
                <span class="eyebrow">Шаг 2</span>
                <h2>Параметры импорта</h2>
            </div>
            <label>
                Часовой пояс логов
                <input class="form-control" @bind="timeZoneId" />
            </label>
            <label class="toggle-line">
                <input type="checkbox" class="form-check-input" @bind="iisLogsAreUtc" />
                <span>IIS уже пишет время в UTC</span>
            </label>
            <label class="toggle-line">
                <input type="checkbox" class="form-check-input" @bind="combineMultiline" />
                <span>Склеивать многострочные exception</span>
            </label>
            <button class="btn btn-primary" @onclick="StartUpload" disabled="@(!selectedFiles.Any() || uploadBusy)">
                @(uploadBusy ? "Импорт запускается..." : "Начать импорт")
            </button>
        </aside>
        @if (!string.IsNullOrWhiteSpace(error))
        {
            <div class="alert alert-danger mt-3">@error</div>
        }
    </section>

    <section class="panel mt-4">
        <h2>История импортов</h2>
        <div class="table-wrap">
            <table class="table app-table">
                <thead>
                    <tr>
                        <th>Статус</th>
                        <th>Файлы</th>
                        <th>Строки</th>
                        <th>Ошибки</th>
                        <th>Текущий файл</th>
                        <th>Начат</th>
                        <th>Завершен</th>
                    </tr>
                </thead>
                <tbody>
                    @if (uploads.Count == 0)
                    {
                        <tr><td colspan="7" class="muted-cell">Импортов пока не было.</td></tr>
                    }
                    else
                    {
                        @foreach (var upload in uploads)
                        {
                            var errors = importErrors.GetValueOrDefault(upload.Id) ?? [];
                            <tr>
                                <td><span class="status-pill @upload.Status">@DisplayStatus(upload.Status)</span></td>
                                <td>@upload.ProcessedFiles / @upload.TotalFiles</td>
                                <td>@upload.ProcessedLines / @upload.TotalLines</td>
                                <td>@upload.ErrorCount</td>
                                <td>@upload.CurrentFile</td>
                                <td>@upload.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                                <td>@(upload.FinishedAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "")</td>
                            </tr>
                            @if (errors.Count > 0)
                            {
                                <tr class="upload-error-row">
                                    <td colspan="7">
                                        <strong>Причина:</strong> @errors[0].ErrorMessage
                                    </td>
                                </tr>
                            }
                        }
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="panel mt-4">
        <h2>Проиндексированные логи</h2>
        <div class="table-wrap">
            <table class="table app-table">
                <thead>
                    <tr>
                        <th>Имя</th>
                        <th>Формат</th>
                        <th>Размер</th>
                        <th>Строки</th>
                        <th>События</th>
                        <th>Ошибки/пред.</th>
                        <th>Первое время</th>
                        <th>Последнее время</th>
                        <th>Статус</th>
                    </tr>
                </thead>
                <tbody>
                    @if (logs.Count == 0)
                    {
                        <tr><td colspan="9" class="muted-cell">Проиндексированных логов пока нет.</td></tr>
                    }
                    else
                    {
                        @foreach (var log in FilteredLogs)
                        {
                            var stat = stats.GetValueOrDefault(log.Id);
                            <tr>
                                <td class="strong" title="@log.DisplayName">@LogFileDisplayName.Format(log)</td>
                                <td>@log.Format</td>
                                <td>@FormatBytes(log.SizeBytes)</td>
                                <td>@log.LineCount</td>
                                <td>@(stat?.EventCount ?? 0)</td>
                                <td>@(stat?.ErrorCount ?? 0) / @(stat?.WarnCount ?? 0)</td>
                                <td>@FormatTime(log.FirstTimestamp)</td>
                                <td>@FormatTime(log.LastTimestamp)</td>
                                <td><span class="status-pill @log.Status">@DisplayStatus(log.Status)</span></td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </section>
    </div>
}

@if (showShareModal && project is not null)
{
    <div class="share-modal-backdrop" @onclick="CloseShareModal"></div>
    <div class="share-modal" role="dialog" aria-modal="true" aria-labelledby="share-modal-title">
        <h2 id="share-modal-title">Ссылка-приглашение</h2>
        <p class="share-modal-hint">Отправьте ссылку коллеге. Она сможет присоединиться к инциденту после входа в аккаунт.</p>
        @if (shareBusy)
        {
            <p class="muted">Готовим ссылку…</p>
        }
        @if (!string.IsNullOrWhiteSpace(shareError))
        {
            <div class="alert alert-danger">@shareError</div>
        }
        @if (!string.IsNullOrWhiteSpace(shareUrl))
        {
            <label class="share-url-label" for="share-url-input">Уникальная ссылка</label>
            <div class="share-url-row">
                <input id="share-url-input" class="form-control" readonly value="@shareUrl" />
            </div>
        }
        <div class="share-modal-actions">
            <button class="btn btn-primary" type="button" @onclick="CloseShareModal">Готово</button>
        </div>
    </div>
}
