@page "/Error"
@using System.Diagnostics

<PageTitle>Ошибка</PageTitle>

<h1 class="text-danger">Ошибка</h1>
<h2 class="text-danger">Не удалось обработать запрос.</h2>

@if (ShowRequestId)
{
    <p>
        <strong>Идентификатор запроса:</strong> <code>@RequestId</code>
    </p>
}

<h3>Режим разработки</h3>
<p>
    В окружении <strong>Development</strong> приложение покажет больше деталей об ошибке.
</p>
<p>
    <strong>Не включайте Development в продуктивном окружении.</strong>
    Подробные исключения могут раскрыть чувствительные данные пользователям.
</p>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
